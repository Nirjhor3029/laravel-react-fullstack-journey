# =============================================================================
# LARAVEL + REACT FULLSTACK JOURNEY - .GITIGNORE
# =============================================================================
# This gitignore is designed for nested Laravel & React projects
# Use **/ to ignore files in any subdirectory
# =============================================================================

# =============================================================================
# NODE.JS / REACT DEPENDENCIES
# =============================================================================
# npm/yarn packages - **/ ignores in any subdirectory
node_modules
**/node_modules

# Yarn lock files - we don't commit lock files for learning projects
**/yarn.lock
**/package-lock.json

# =============================================================================
# LARAVEL DEPENDENCIES
# =============================================================================
# Composer dependencies
vendor
**/vendor

# Environment files - contain secrets, NEVER commit these
.env
**/.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env.*

# Laravel storage (logs, cache, sessions)
storage/*.key
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
storage/logs/*
**/storage/*.key
**/storage/framework/cache/*
**/storage/framework/sessions/*
**/storage/framework/views/*
**/storage/logs/*

# =============================================================================
# BUILD OUTPUTS
# =============================================================================
# Production build files
build
dist
**/build
**/dist

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# TESTING
# =============================================================================
coverage
.phpunit
**/coverage

# =============================================================================
# IDE & EDITORS
# =============================================================================
.idea        # PhpStorm
.vscode     # VS Code
*.swp       # Vim swap
*.swo       # Vim swap
*~          # Vim backup

# =============================================================================
# OPERATING SYSTEM
# =============================================================================
.DS_Store   # macOS
Thumbs.db   # Windows
